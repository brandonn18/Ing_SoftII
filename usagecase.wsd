@startuml
left to right direction

actor Usuario
actor Tecnico
actor Administrador

rectangle "Sistema de Gestión de Tickets TI" {

  ' Casos de uso Usuario
  usecase "Crear ticket" as CU1
  usecase "Consultar ticket" as CU2
  usecase "Reabrir ticket" as CU3
  usecase "Ver dashboard" as CU4

  ' Casos de uso Técnico
  usecase "Consultar tickets asignados" as CU5
  usecase "Gestionar ticket" as CU6
  usecase "Cambiar estado" as CU7
  usecase "Registrar solución" as CU8

  ' Casos de uso Administrador
  usecase "Gestionar usuarios" as CU9
  usecase "Registrar técnicos" as CU10
  usecase "Asignar categorías a técnicos" as CU11
  usecase "Supervisar tickets" as CU12

  ' Casos internos del sistema
  usecase "Asignación automática" as CU13

}

' Relaciones Usuario
Usuario --> CU1
Usuario --> CU2
Usuario --> CU3
Usuario --> CU4

' Relaciones Técnico
Tecnico --> CU5
Tecnico --> CU6
Tecnico --> CU7
Tecnico --> CU8
Tecnico --> CU4

' Relaciones Administrador
Administrador --> CU9
Administrador --> CU10
Administrador --> CU11
Administrador --> CU12
Administrador --> CU4

' Relaciones include
CU1 --> CU13 : <<include>>
CU6 --> CU7 : <<include>>
CU6 --> CU8 : <<include>>

' Relaciones extend
CU3 ..> CU2 : <<extend>>

@enduml